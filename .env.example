# APIYI_API_KEY: Required for Nano Banana image generation + Gemini text/vision (server-side, via API易)
APIYI_API_KEY=""

# DASHSCOPE_API_KEY: Required for DashScope video generation calls (server-side in production)
DASHSCOPE_API_KEY=""

# Optional for local development only (NEVER set these in production; VITE_* is exposed to browsers)
VITE_DASHSCOPE_API_KEY=""
VITE_VIDU_REQUIRE_HTTP_URL=false
VITE_DASHSCOPE_VIDEO_MODEL="kling-v3-omni-video-generation"
VITE_DASHSCOPE_VIDEO_MODE="pro"
VITE_DASHSCOPE_VIDEO_DURATION_SECONDS=6
VITE_DASHSCOPE_VIDEO_ENABLE_AUDIO=false
VITE_DASHSCOPE_VIDEO_SIZE="1920*1080"

# Image generation (Nano Banana 2 by default)
# Nano Banana Pro: gemini-3-pro-image-preview
# Nano Banana 2: gemini-3.1-flash-image-preview
VITE_GEMINI_IMAGE_MODEL="gemini-3.1-flash-image-preview"
VITE_CHARACTER_SHEET_IMAGE_SIZE="2K"

# Image understanding / prompt generation (Gemini text/vision)
VITE_GEMINI_VISION_MODEL="gemini-2.5-flash"
VITE_GEMINI_TEXT_MODEL="gemini-2.5-flash"

# Feature flags (local/dev only)
VITE_ENABLE_PET_ANALYSIS=false
VITE_ENABLE_VIDEO_AUTO_PROMPT=false

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Server runtime
PORT=3000

# Optional outbound proxy for the production server
HTTP_PROXY=""
