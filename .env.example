# APIYI_API_KEY: Required for image generation + image understanding (server-side, via API易 OpenAI compatible gateway)
APIYI_API_KEY=""

# DASHSCOPE_API_KEY: Required for DashScope video generation calls (server-side in production)
DASHSCOPE_API_KEY=""

# Optional for local development only (NEVER set these in production; VITE_* is exposed to browsers)
VITE_DASHSCOPE_API_KEY=""
VITE_VIDU_REQUIRE_HTTP_URL=false
VITE_DASHSCOPE_VIDEO_MODEL="wan2.6-i2v-flash"

# Image generation (gpt-image-2)
VITE_OPENAI_IMAGE_MODEL="gpt-image-2"
VITE_OPENAI_IMAGE_QUALITY="high"
VITE_OPENAI_IMAGE_FORMAT="png"
VITE_CHARACTER_SHEET_IMAGE_SIZE="2K"

# Image understanding / prompt generation (chat.completions vision/text)
VITE_OPENAI_VISION_MODEL="gpt-4o-mini"
VITE_OPENAI_TEXT_MODEL="gpt-4o-mini"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Server runtime
PORT=3000

# Optional outbound proxy for the production server
HTTP_PROXY=""
