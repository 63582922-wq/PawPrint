# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=""

# DASHSCOPE_API_KEY: Required for DashScope / Vidu video generation calls (server-side in production)
DASHSCOPE_API_KEY=""

# Optional for local development only (NEVER set these in production; VITE_* is exposed to browsers)
VITE_GEMINI_API_KEY=""
VITE_DASHSCOPE_API_KEY=""
VITE_GEMINI_USE_LOCAL_PROXY=false
DEV_HTTP_PROXY="http://127.0.0.1:33210"
VITE_GEMINI_IMAGE_MODEL="gemini-2.5-flash-image"
VITE_CHARACTER_SHEET_IMAGE_SIZE="2K"
VITE_VIDU_REQUIRE_HTTP_URL=false
VITE_DASHSCOPE_VIDEO_MODEL="wan2.6-I2V-flash"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Server runtime
PORT=3000

# Optional outbound proxy for the production server
HTTP_PROXY=""
